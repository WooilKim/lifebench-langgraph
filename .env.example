# LLM Provider: claude, gpt, glm
LLM_PROVIDER=claude

# Anthropic
ANTHROPIC_API_KEY=your-key-here

# OpenAI
OPENAI_API_KEY=your-key-here

# GLM (online, OpenAI-compatible)
GLM_BASE_URL=http://your-glm-server/v1
GLM_API_KEY=your-glm-key
GLM_MODEL=glm-4

# Optional model overrides
CLAUDE_MODEL=claude-sonnet-4-6
GPT_MODEL=gpt-4o

# LifeBench data directory
LIFEBENCH_DATA_DIR=/Users/wooil/source/LifeBench/life_bench_data/data_en
